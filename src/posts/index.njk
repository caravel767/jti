---
layout: base.njk
title: All Articles
description: A complete list of our travel guides and insights.
---
<header class="page-header header-posts">
  <div class="container">
    <h1>All Articles</h1>
    <p>Explore our complete collection of Japan travel guides and tips.</p>
  </div>
</header>

<div class="container">
  <section class="post-grid">
    {% for post in collections.posts | reverse %}
    <article class="post-card">
      <div class="post-card-image">
        {% if post.data.image %}
        <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
        {% else %}
        <div class="placeholder-img"></div>
        {% endif %}
      </div>
      <div class="post-card-content">
        <div class="post-card-meta">
          <span class="post-date">{{ post.date | dateReadable }}</span>
        </div>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        <p>{{ post.data.description }}</p>
        <a href="{{ post.url }}" class="read-more">Read Full Guide &rarr;</a>
      </div>
    </article>
    {% endfor %}
  </section>
</div>
