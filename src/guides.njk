---
layout: base.njk
title: Travel Guides
description: Comprehensive guides to help you plan your perfect trip to Japan.
permalink: /guides/
---
<header class="page-header header-guides">
  <div class="container">
    <h1>Travel Guides</h1>
    <p>Everything you need to know for your journey, organized by experts.</p>
  </div>
</header>

<div class="container">
  <section class="post-grid">
    {% for post in collections.posts | reverse %}
      {# 
         Exclude specific posts that are better suited for Tips & Info or are specific hotel guides.
         Check against the file slug or title.
      #}
      {% set isExcluded = false %}
      {% if post.data.title == "How to Book Shinkansen (Bullet Train) Tickets Online" %} {% set isExcluded = true %} {% endif %}
      {% if post.data.title == "Where to Stay in Kyoto: Top 5 Boutique Hotels Near Major Temples" %} {% set isExcluded = true %} {% endif %}
      {% if post.data.title == "Japan Travel Essentials: WiFi, eSim, and Apps You Need" %} {% set isExcluded = true %} {% endif %}

      {% if not isExcluded %}
      <article class="post-card">
        <div class="post-card-image">
          {% if post.data.image %}
          <img src="{{ post.data.image }}" alt="{{ post.data.title }}">
          {% else %}
          <div class="placeholder-img"></div>
          {% endif %}
        </div>
        <div class="post-card-content">
          <div class="post-card-meta">
            <span class="post-date">{{ post.date | dateReadable }}</span>
          </div>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p>{{ post.data.description }}</p>
          <a href="{{ post.url }}" class="read-more">Read Full Guide &rarr;</a>
        </div>
      </article>
      {% endif %}
    {% endfor %}
  </section>
</div>
